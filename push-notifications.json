const VAPID_KEY = 'BORIFeyU_kWXx-V3VD-t4BauHd6vq49HIcVEOCRnxi8tcvoPFjwcNeaS7IfDynMRI9f6wM4YV712Jh6tfL5Y6f0';

async function inicializarPushNotifications() {
    if (!firebase.messaging) return;
    if (!('Notification' in window)) return;
    if (Notification.permission === 'denied') return;
    
    try {
        const messaging = firebase.messaging();
        
        if (Notification.permission !== 'granted') {
            const permission = await Notification.requestPermission();
            if (permission !== 'granted') return;
        }
        
        const token = await messaging.getToken({ vapidKey: VAPID_KEY });
        console.log("Token FCM obtido:", token);
        
        if (currentUser && currentUser.uid && !currentUser.isVisitante) {
            await database.ref(`users/${currentUser.uid}/fcmToken`).set(token);
        }
        
        messaging.onMessage((payload) => {
            console.log("Notificação em foreground:", payload);
            mostrarNotificacaoLocal(
                payload.notification?.title || 'KayaMoz',
                payload.notification?.body || 'Nova atualização!'
            );
            if (typeof carregarNotificacoesBadge === 'function') carregarNotificacoesBadge();
        });
    } catch (error) {
        console.error("Erro push:", error);
    }
}

function mostrarNotificacaoLocal(titulo, corpo) {
    if (Notification.permission === 'granted') {
        const notification = new Notification(titulo, {
            body: corpo,
            icon: '/icon-192.png',
            vibrate: [200, 100, 200]
        });
        notification.onclick = () => {
            window.focus();
            window.location.href = '/page1.html';
            notification.close();
        };
    }
    if (typeof showToast === 'function') {
        showToast(`🔔 ${titulo}: ${corpo}`);
    }
}
